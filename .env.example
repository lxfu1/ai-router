# AI Router - 环境变量配置
# 复制此文件为 .env.local 并填写你的 API 密钥

# ========== 上游模型 API 配置 ==========

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 智谱 GLM
ZHIPU_API_KEY=your-zhipu-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 通义千问
QWEN_API_KEY=your-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# MiniMax（可选）
MINIMAX_API_KEY=your-minimax-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# ========== 管理后台配置 ==========

# 管理员密码
ADMIN_PASSWORD=your-strong-admin-password

# JWT 会话密钥（生成随机字符串）
JWT_SECRET=generate-a-random-secret-string-here

# ========== 安全配置 ==========

# 密钥加密密钥（32字节 hex，可用 `openssl rand -hex 32` 生成）
# 如未设置，将从 JWT_SECRET 派生
ENCRYPTION_KEY=

# CORS 允许的来源（逗号分隔，留空或 * 表示允许所有）
# 例如: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# API 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60
RATE_LIMIT_IP_RPM=120

# ========== 数据库配置（P1 - 可选） ==========

# 数据库类型: sqlite（默认）或 postgres
DATABASE_TYPE=sqlite

# PostgreSQL 连接串（仅当 DATABASE_TYPE=postgres 时需要）
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_router

# ========== 缓存配置（P1 - 可选） ==========

# Redis 连接串（留空则使用内存缓存）
# REDIS_URL=redis://localhost:6379

# ========== 日志配置 ==========

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 日志格式: json 或 text
LOG_FORMAT=json

# ========== 监控配置 ==========

# Prometheus 指标端点访问令牌（留空则不认证）
# METRICS_AUTH_TOKEN=your-metrics-token
